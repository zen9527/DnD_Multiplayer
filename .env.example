# ============================================
# LLM API Configuration (OpenAI-compatible)
# ============================================
# Supports: LM Studio, Ollama, OpenAI, Azure, Together AI, Groq, etc.
# 
# IMPORTANT: Copy this file to .env and fill in your actual values!
# The .env file is ignored by Git to protect your credentials.

# ============================================
# Local Development (LM Studio - Default)
# ============================================
VITE_LLM_API_URL=http://localhost:1234/v1
VITE_LLM_API_KEY=

# ============================================
# Alternative Providers (uncomment and configure to use)
# ============================================

# OpenAI
# VITE_LLM_API_URL=https://api.openai.com/v1
# VITE_LLM_API_KEY=sk-your-openai-key-here

# Ollama (local, typically no auth required)
# VITE_LLM_API_URL=http://localhost:11434/v1
# VITE_LLM_API_KEY=

# Together AI
# VITE_LLM_API_URL=https://api.together.xyz/v1
# VITE_LLM_API_KEY=your_together_api_key

# Groq
# VITE_LLM_API_URL=https://api.groq.com/openai/v1
# VITE_LLM_API_KEY=your_groq_api_key

# Anthropic (Claude)
# VITE_LLM_API_URL=https://api.anthropic.com/v1
# VITE_LLM_API_KEY=sk-ant-your-anthropic-key

# ============================================
# Notes:
# - URL format: {host}:{port}/v1 (for OpenAI-compatible APIs)
# - API Key is optional for local servers (LM Studio, Ollama)
# - Required for cloud providers (OpenAI, Together, Groq, etc.)
# ============================================
